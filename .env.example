POSTGRES_PASSWORD=change-me
ORIGIN=https://your-reverse-proxied-hostname

# Authentik OIDC SSO (see docs/superpowers/specs/2026-07-17-authentik-oidc-sso-design.md).
# PUBLIC_BASE_URL is the externally-visible base URL of this app (matches ORIGIN above).
# Invariant: OIDC_REDIRECT_URI must equal PUBLIC_BASE_URL + "/api/auth/oidc/callback".
PUBLIC_BASE_URL=https://your-reverse-proxied-hostname
OIDC_ISSUER_URL=https://your-authentik-host/application/o/your-app-slug/
OIDC_CLIENT_ID=your-app-slug
OIDC_CLIENT_SECRET=change-me
OIDC_REDIRECT_URI=https://your-reverse-proxied-hostname/api/auth/oidc/callback

# Local dev example (against the stub e2e/support/fake-oidc-provider.mjs — see app/README.md).
# OIDC_ALLOW_INSECURE=1 is required because the stub speaks plain http (openid-client
# refuses http issuers otherwise). Never set it in production.
#   PUBLIC_BASE_URL=http://localhost:5173
#   OIDC_ISSUER_URL=http://localhost:9099
#   OIDC_CLIENT_ID=test-client
#   OIDC_CLIENT_SECRET=test-secret
#   OIDC_REDIRECT_URI=http://localhost:5173/api/auth/oidc/callback
#   OIDC_ALLOW_INSECURE=1
